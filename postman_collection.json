					"name": "Get All Tasks (Admin Only)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"url": {
							"raw": "http://localhost:5000/api/v1/tasks/all",
							"protocol": "http",
							"host": ["localhost"],
